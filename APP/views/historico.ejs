<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Histórico de Acessos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">Portaria Digital</a>
            <div class="navbar-nav">
                <a class="nav-link" href="/">Moradores</a>
                <a class="nav-link" href="/registro">Novo Registro</a>
                <a class="nav-link active" href="/historico">Histórico</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="card shadow">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h2 class="mb-0">Histórico Completo de Acessos</h2>
                <a href="/registro" class="btn btn-outline-light btn-sm">Novo Registro</a>
            </div>
            <div class="card-body">
                <table class="table table-hover">
                    <thead class="table-secondary">
                        <tr>
                            <th>Morador</th>
                            <th>Entrada</th>
                            <th>Saída</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (acessos && acessos.length > 0) { %>
                            <% acessos.forEach(acesso => { %>
                                <tr>
                                    <td><strong><%= acesso.Nome %></strong></td>
                                    <td><%= new Date(acesso.data_entrada).toLocaleString('pt-BR') %></td>
                                    <td><%= acesso.data_saida ? new Date(acesso.data_saida).toLocaleString('pt-BR') : '---' %></td>
                                    <td>
                                        <% if (!acesso.data_saida) { %>
                                            <span class="badge bg-success">No Prédio</span>
                                        <% } else { %>
                                            <span class="badge bg-secondary">Saiu</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" class="text-center">Nenhum acesso registrado ainda.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>