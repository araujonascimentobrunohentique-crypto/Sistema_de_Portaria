<!DOCTYPE html>
<html lang="pt-br">

<head>
    <!-- Configurações básicas -->
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Histórico de Acessos</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/historico.css">


</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm mb-5">
        <div class="container">

            <!-- Logo -->
            <a class="navbar-brand fw-bold text-dark" href="/">
                <span class="text-secondary">Portaria</span>Digital
            </a>

            <!-- Links -->
            <div class="navbar-nav ms-auto">
                <a class="nav-link text-muted" href="/">Moradores</a>
                <a class="nav-link text-muted" href="/registro">Registrar Entrada/Saída</a>
                <a class="nav-link active fw-semibold" href="/historico">Histórico</a>
            </div>

        </div>
    </nav>

    <!-- Conteúdo -->
    <div class="container">

        <!-- Título + botão -->
        <div class="row align-items-center mb-4">
    <div class="col-md-4">
        <h4 class="text-secondary fw-light mb-0">Logs de Atividade</h4>
    </div>

    <div class="col-md-5">
        <form action="/historico" method="GET" class="d-flex">
            <input type="text" name="busca" class="form-control form-control-sm me-2"
                placeholder="Pesquisar por Nome..." 
                value="<%= (typeof busca !== 'undefined') ? busca : '' %>">
            <button type="submit" class="btn btn-sm btn-secondary">🔍</button>
            
            <% if (typeof busca !== 'undefined' && busca !== '') { %>
                <a href="/historico" class="btn btn-sm btn-link text-decoration-none">Limpar</a>
            <% } %>
        </form>
    </div>

    <div class="col-md-3 text-end">
        <a href="/registro" class="btn btn-sm btn-outline-dark px-3">Novo Registro</a>
    </div>
</div>

        <!-- Card da tabela -->
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">

                <div class="table-responsive">
                    <!-- Tabela -->
                    <table class="table table-hover align-middle mb-0">

                        <!-- Cabeçalho -->
                        <thead>
                            <tr>
                                <th class="ps-4 py-3">Morador</th>
                                <th class="py-3 text-center">Entrada</th>
                                <th class="py-3 text-center">Saída</th>
                                <th class="py-3 text-end pe-4">Status</th>
                            </tr>
                        </thead>

                        <!-- Corpo -->
                        <tbody>

                            <% if (acessos && acessos.length> 0) { %>
                                <!-- Se tiver dados -->

                                <% acessos.forEach(acesso=> { %>
                                    <!-- Loop -->

                                    <tr>

                                        <!-- Nome -->
                                        <td class="ps-4 py-3">
                                            <span class="fw-semibold text-dark">
                                                <%= acesso.Nome %>
                                            </span>
                                        </td>

                                        <!-- Entrada -->
                                        <td class="text-center text-muted small">
                                            <%= new Date(acesso.data_entrada).toLocaleString('pt-BR', { day: '2-digit' ,
                                                month: '2-digit' , hour: '2-digit' , minute: '2-digit' }) %>
                                        </td>

                                        <!-- Saída -->
                                        <td class="text-center text-muted small">
                                            <%= acesso.data_saida ? new Date(acesso.data_saida).toLocaleString('pt-BR',
                                                { day: '2-digit' , month: '2-digit' , hour: '2-digit' ,
                                                minute: '2-digit' }) : '---' %>
                                        </td>

                                        <!-- Status -->
                                        <td class="text-end pe-4">
                                            <% if (!acesso.data_saida) { %>
                                                <span class="badge badge-in px-3 py-2 rounded-pill">
                                                    No Prédio
                                                </span>
                                                <% } else { %>
                                                    <span class="badge badge-out px-3 py-2 rounded-pill">
                                                        Saiu
                                                    </span>
                                                    <% } %>
                                        </td>

                                    </tr>

                                    <% }) %>

                                        <% } else { %>
                                            <!-- Sem dados -->

                                            <tr>
                                                <td colspan="4" class="text-center py-5 text-muted">
                                                    Nenhum acesso registrado no histórico.
                                                </td>
                                            </tr>

                                            <% } %>

                        </tbody>
                    </table>
                </div>

            </div>
        </div>

        <!-- Rodapé -->
        <div class="text-center mt-4">
            <p class="text-muted small">
                Mostrando os registros mais recentes em tempo real.
            </p>
        </div>

    </div>

</body>

</html>