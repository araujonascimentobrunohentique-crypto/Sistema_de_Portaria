<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Registrar Acesso</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-5">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h2>Registrar Entrada ou Saída</h2>
        </div>
        <div class="card-body">
            <p>Selecione o morador e a ação desejada:</p>
            
            <form id="formAcesso" method="POST">
                <div class="mb-4">
                    <label for="id_morador" class="form-label">Morador:</label>
                    <select name="id_morador" id="id_morador" class="form-select form-select-lg" required>
                        <option value="" disabled selected>Escolha um morador...</option>
                        <% moradores.forEach(morador => { %>
                            <option value="<%= morador.id %>"><%= morador.Nome %> (CPF: <%= morador.CPF %>)</option>
                        <% }) %>
                    </select>
                </div>

                <div class="d-grid gap-3 d-md-flex justify-content-md-center">
                    <button type="submit" onclick="enviarPara('/entrada')" class="btn btn-success btn-lg px-5">
                        Registrar ENTRADA
                    </button>
                    <button type="submit" onclick="enviarPara('/saida')" class="btn btn-danger btn-lg px-5">
                        Registrar SAÍDA
                    </button>
                </div>
            </form>
        </div>
        <div class="card-footer">
            <a href="/" class="btn btn-secondary">Voltar para Listagem</a>
        </div>
    </div>

    <script>
        // Função simples para mudar a rota de destino dependendo do botão clicado
        function enviarPara(rota) {
            document.getElementById('formAcesso').action = rota;
        }
    </script>
</body>
</html>