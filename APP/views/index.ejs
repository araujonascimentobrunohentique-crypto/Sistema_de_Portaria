<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portaria - Moradores</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
    <div class="container">
        <a class="navbar-brand" href="/">Portaria Digital</a>
        <div class="navbar-nav">
            <a class="nav-link active" href="/">Moradores</a>
            <a class="nav-link" href="/registro">Novo Registro</a>
            <a class="nav-link" href="/historico">Histórico de Acessos</a>
        </div>
    </div>
</nav>

    <div class="container mt-5">
        <h1 class="mb-4">Sistema de Portaria</h1>

        <div class="card mb-5">
            <div class="card-header bg-primary text-white">Cadastrar Morador</div>
            <div class="card-body">
                <form action="/adicionar" method="POST" class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Nome Completo</label>
                        <input type="text" name="Nome" class="form-control" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">CPF</label>
                        <input type="text" name="CPF" class="form-control" required>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-success w-100">Salvar</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-secondary text-white">Pessoas Cadastradas</div>
            <div class="card-body">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nome</th>
                            <th>CPF</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (dados && dados.length> 0) { %>
                            <% dados.forEach(pessoa=> { %>
                                <tr>
                                    <td>
                                        <%= pessoa.id %>
                                    </td>
                                    <td>
                                        <%= pessoa.Nome %>
                                    </td>
                                    <td>
                                        <%= pessoa.CPF %>
                                    </td>
                                 
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="4" class="text-center">Nenhuma pessoa cadastrada.</td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</body>

</html>